NODE_ENV=development
PORT=3000

# Runtime app-role connection (non-superuser, RLS-enforced). Used by the API
# and the seed CLI for all tenant-scoped reads/writes.
DATABASE_URL=postgresql://app_user:app_user_dev_password@localhost:5432/mysociety

# Elevated connection used only by the migration runner (DDL, role/grant
# management). Never used for tenant-scoped reads/writes.
ADMIN_DATABASE_URL=postgresql://postgres:postgres@localhost:5432/mysociety

REDIS_URL=redis://localhost:6379
SEED_ENABLED=false
SMS_PROVIDER=console
PAYMENT_PROVIDER=fake
JWT_SECRET=change-this-to-a-real-secret

# 32-byte AES-256 key encoded as 64 hex chars. Required in production for
# encrypting integration connector credentials at rest.
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
INTEGRATION_ENCRYPTION_KEY=

# URL used by the admin and resident Next.js apps to reach the API.
# In production, set this to your deployed API service URL, e.g.:
#   API_URL=https://api-mysociety.up.railway.app
API_URL=http://localhost:3000
