NODE_ENV=development
PORT=3000

# Runtime app-role connection (non-superuser, RLS-enforced). Used by the API
# and the seed CLI for all tenant-scoped reads/writes.
DATABASE_URL=postgresql://app_user:app_user_dev_password@localhost:5432/mysociety

# Elevated connection used only by the migration runner (DDL, role/grant
# management). Never used for tenant-scoped reads/writes.
ADMIN_DATABASE_URL=postgresql://postgres:postgres@localhost:5432/mysociety

REDIS_URL=redis://localhost:6379
SEED_ENABLED=false
SMS_PROVIDER=console
PAYMENT_PROVIDER=fake
JWT_SECRET=change-this-to-a-real-secret
